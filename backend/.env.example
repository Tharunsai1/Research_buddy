# Copy this file to .env to override defaults.
#
# ---------------------------------------------------------------------------
# Provider: openrouter (default) | ollama | anthropic
# ---------------------------------------------------------------------------
# OpenRouter — hosted models. The default model is free to call; get a key at
# https://openrouter.ai/keys  (free tier: 20 req/min, and 50 req/day until the
# account has ever held $10 in credit, then 1000/day).
OPENROUTER_API_KEY=sk-or-v1-...
# RC_PROVIDER=openrouter
# RC_OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# RC_OPENROUTER_RPM=18          # client-side cap; keep below OpenRouter's 20/min
# RC_OPENROUTER_RETRIES=4
# RC_OPENROUTER_TIMEOUT=300

# Local models via Ollama (no key, fully offline):
#   ollama pull qwen3:8b
# RC_PROVIDER=ollama
# RC_OLLAMA_MODEL=qwen3:8b
# RC_OLLAMA_URL=http://127.0.0.1:11434
# RC_OLLAMA_CTX=16384
# RC_OLLAMA_THINK=1         # let thinking models reason before answering (slower,
                            # and needs headroom — leave off for gemma4:12b)

# Anthropic API:
# RC_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# RC_MODEL=claude-opus-4-8

# ---------------------------------------------------------------------------
# Embeddings — always local, used only by chat-with-paper.
# OpenRouter is a chat-completions gateway and does not serve this model.
#   ollama pull nomic-embed-text
# ---------------------------------------------------------------------------
# RC_EMBED_MODEL=nomic-embed-text

# Citation data (Semantic Scholar). Works with no key; a free key just raises
# the shared rate limit: https://www.semanticscholar.org/product/api
# S2_API_KEY=

# Pipeline tuning
# RC_PAPERS=8               # papers per search
# RC_CANDIDATES=60          # max arXiv candidates before reranking
# RC_CROSS_ENCODER=cross-encoder/ms-marco-MiniLM-L-6-v2
# RC_DISABLE_CE=1           # skip the cross-encoder (LLM-only ranking)
